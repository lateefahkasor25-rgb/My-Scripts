-- --- [Tab: Main] ปุ่มกด ESP ตามภาพที่คุณต้องการ ---
TabMain:CreateSection("ESP Settings")

TabMain:CreateButton({
   Name = "ESP Killer (ผู้เน่า/โปรเจ็ค/Ennard)",
   Callback = function()
       for _, p in pairs(Players:GetPlayers()) do
           if p ~= Players.LocalPlayer and p.Character then
               local kname = nil
               for _, v in pairs(p.Character:GetDescendants()) do
                   if v.Name:lower():match("spring") or v.Name:lower():match("ตน") then kname = "ผู้เน่า" break
                   elseif v.Name:lower():match("endo") or v.Name:lower():match("project") then kname = "โปรเจ็ค" break
                   elseif v.Name:lower():match("ennard") or v.Name:lower():match("minion") then kname = "Ennard's minions" break
                   elseif v.Name:lower():match("doppel") then kname = "Doppelganger" break
                   end
               end
               if kname or not p.Character:FindFirstChildOfClass("Shirt") then
                   applyESP(p.Character, Color3.fromRGB(255, 0, 0), "JobESP", "⚠️ " .. (kname or "นักฆ่า"))
               end
           end
       end
   end,
})

TabMain:CreateButton({
   Name = "ESP Generator (เครื่องปั่นไฟ)",
   Callback = function()
       for _, obj in pairs(game.Workspace:GetDescendants()) do
           local isGen = false; local target = nil
           if obj.Name:lower():match("ekcm") or obj.Name:lower():match("generator") then isGen = true target = obj
           elseif obj:IsA("ProximityPrompt") and (obj.ActionText:lower():match("repair") or obj.ObjectText:lower():match("gen")) then isGen = true target = obj.Parent
           end
           if isGen and target then applyESP(target, Color3.fromRGB(255, 200, 0), "JobESP", "⚙️ Generator") end
       end
   end,
})

TabMain:CreateButton({
   Name = "ESP Survivors (ผู้รอดชีวิต)",
   Callback = function()
       for _, p in pairs(Players:GetPlayers()) do
           if p ~= Players.LocalPlayer and p.Character then
               local jName = "ผู้รอดชีวิต"; local jColor = Color3.fromRGB(0, 150, 255)
               local isMedic = false
               for _, v in pairs(p.Character:GetDescendants()) do
                   if v.Name:lower():match("med") or v.Name:lower():match("heal") or v.Name:lower():match("medical") then isMedic = true break end
               end
               if isMedic then jName = "หมอ"; jColor = Color3.fromRGB(0, 255, 100)
               else
                   for _, v in pairs(p.Character:GetDescendants()) do
                       if v.Name:lower():match("stun") or v.Name:lower():match("taser") then jName = "ยาม"; jColor = Color3.fromRGB(255, 255, 0) break
                       elseif v.Name:lower():match("axe") or v.Name:lower():match("crowbar") then jName = "นักรบ"; jColor = Color3.fromRGB(255, 50, 0) break
                       end
                   end
               end
               applyESP(p.Character, jColor, "JobESP", jName)
           end
       end
   end,
})

TabMain:CreateButton({
   Name = "ESP Battery (แบตเตอรี่)",
   Callback = function()
