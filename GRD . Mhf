-- --- ฟังก์ชัน Core ของคุณ (คงเดิม 100%) ---
local function createNameTag(target, text, color)
    local targetPart = target:IsA("Model") and (target:FindFirstChild("Head") or target:FindFirstChildOfClass("BasePart") or target.PrimaryPart) or target
    if not targetPart then return end
    if targetPart:FindFirstChild("ClassTag") then targetPart.ClassTag:Destroy() end
    local bgui = Instance.new("BillboardGui", targetPart)
    bgui.Name = "ClassTag"; bgui.Size = UDim2.new(0, 200, 0, 50); bgui.AlwaysOnTop = true; bgui.ExtentsOffset = Vector3.new(0, 3, 0)
    local label = Instance.new("TextLabel", bgui)
    label.Size = UDim2.new(1, 0, 1, 0); label.BackgroundTransparency = 1; label.Text = text; label.TextColor3 = color; label.TextStrokeTransparency = 0; label.TextSize = 18; label.Font = Enum.Font.GothamBold
end

local function applyESP(target, color, tag, className)
    if not target then return end
    if target:FindFirstChild(tag) then target[tag]:Destroy() end
    local h = Instance.new("Highlight", target)
    h.Name = tag; h.FillColor = color; h.OutlineColor = Color3.new(1, 1, 1); h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    createNameTag(target, className, color)
end

local function removeESP(tag)
    for _, v in pairs(game:GetDescendants()) do
        if v.Name == tag or v.Name == "ClassTag" then v:Destroy() end
    end
end

