local function createNameTag(target, text, color)
    local targetPart = target:IsA("Model") and (target:FindFirstChild("Head") or target:FindFirstChildOfClass("BasePart") or target.PrimaryPart) or target
    if not targetPart then return end
    if targetPart:FindFirstChild("ClassTag") then targetPart.ClassTag:Destroy() end
    local bgui = Instance.new("BillboardGui", targetPart)
    bgui.Name = "ClassTag"
    bgui.Size = UDim2.new(0, 250, 0, 50)
    bgui.AlwaysOnTop = true
    bgui.ExtentsOffset = Vector3.new(0, 3, 0)
    local label = Instance.new("TextLabel", bgui)
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = color
    label.TextStrokeTransparency = 0
    label.TextSize = 22
    label.Font = Enum.Font.SourceSansBold
end

local function applyESP(target, color, tag, className)
    if not target then return end
    if target:FindFirstChild(tag) then target[tag]:Destroy() end
    local h = Instance.new("Highlight", target)
    h.Name = tag
    h.FillColor = color
    h.OutlineColor = Color3.new(1, 1, 1)
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    createNameTag(target, className, color)
end

-- --- แก้ไข: ฟังก์ชันสแกนเครื่องปั่นไฟแบบครอบคลุมทุกเงื่อนไข ---
local function scanGeneratorsUltimate()
    local foundCount = 0
    for _, obj in pairs(game.Workspace:GetDescendants()) do
        local isGen = false
        local target = nil
        
        -- เงื่อนไข 1: เจอชื่อยี่ห้อ EKCM หรือชื่อ Generator
        if obj.Name:lower():match("ekcm") or obj.Name:lower():match("generator") then
            isGen = true
            target = obj
        -- เงื่อนไข 2: เจอคำสั่ง Repair (ซ่อม)
        elseif obj:IsA("ProximityPrompt") and (obj.ActionText:lower():match("repair") or obj.ObjectText:lower():match("gen")) then
            isGen = true
            target = obj.Parent
        -- เงื่อนไข 3: เจอแถบพลังงาน (ProgressBar) ที่มักจะอยู่บนเครื่องปั่นไฟ
        elseif obj:IsA("BillboardGui") and (obj.Name:lower():match("health") or obj.Name:lower():match("progress")) then
            if obj.Parent and not Players:GetPlayerFromCharacter(obj.Parent) then -- ต้องไม่ใช่บนหัวคน
                isGen = true
                target = obj.Parent
            end
        end

        if isGen and target then
            applyESP(target, Color3.fromRGB(255, 200, 0), "JobESP", "⚙️ เครื่องปั่นไฟ")
            foundCount = foundCount + 1
        end
    end
end

local function createBtn(text, color, pos, callback)
    local btn = Instance.new("TextButton", Main)
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Position = UDim2.new(0.05, 0, 0, pos)
    btn.Text = text
    btn.BackgroundColor3 = color
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.SourceSansBold
    btn.MouseButton1Click:Connect(callback)
end

