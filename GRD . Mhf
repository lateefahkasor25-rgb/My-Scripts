-- --- [Tab: Speed & Stamina] หน้าวิ่งไวและวิ่งไม่เหนื่อย ---
TabSpeed:CreateSection("Movement & Energy")

TabSpeed:CreateSlider({
   Name = "WalkSpeed (ความเร็ว)",
   Range = {1, 30},
   Increment = 1,
   Suffix = " Speed",
   CurrentValue = 16,
   Flag = "SpeedSlider", 
   Callback = function(Value)
      if Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("Humanoid") then
          Players.LocalPlayer.Character.Humanoid.WalkSpeed = Value
      end
   end,
})

TabSpeed:CreateToggle({
   Name = "🏃 Infinite Stamina (วิ่งไม่เหนื่อย)",
   CurrentValue = false,
   Callback = function(Value)
      _G.InfStamina = Value
      task.spawn(function()
          while _G.InfStamina do
              task.wait()
              local char = Players.LocalPlayer.Character
              if char then
                  local stamina = char:FindFirstChild("Stamina") or Players.LocalPlayer:FindFirstChild("Stamina")
                  if stamina and (stamina:IsA("NumberValue") or stamina:IsA("IntValue")) then
                      stamina.Value = 100
                  end
              end
          end
      end)
   end,
})

